{
  "expo": {
    "name": "Apna Counsellor",
    "slug": "apna-counsellor",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apnacounsellor",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apnacounsellor.app"
    },
    "android": {
      "package": "com.apnacounsellor.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "3340feef-5567-47cd-9b5c-69efcff43603"
      }
    }
  }
}
